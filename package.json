{
  "name": "@clawkeys/ck",
  "version": "0.1.0",
  "description": "TypeScript OpenCode + CH57x control CLI backed by Node-API binaries",
  "repository": {
    "type": "git",
    "url": "https://github.com/blairhudson/clawkeys"
  },
  "type": "module",
  "bin": {
    "ck": "./bin/ck.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "README.md",
    "clawkeys.png"
  ],
  "scripts": {
    "build": "npm run build:ts && npm run build:napi",
    "build:ts": "tsc",
    "build:napi": "napi build --release --platform --js-package-name @clawkeys/ck --manifest-path ./crates/native/Cargo.toml",
    "lint": "npm run build:ts -- --pretty false",
    "test": "npm run build:ts && node --test",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "@clawkeys/ck-darwin-arm64": "0.1.0",
    "@clawkeys/ck-darwin-x64": "0.1.0",
    "@clawkeys/ck-linux-x64-gnu": "0.1.0",
    "@clawkeys/ck-linux-arm64-gnu": "0.1.0",
    "@clawkeys/ck-linux-x64-musl": "0.1.0",
    "@clawkeys/ck-win32-x64-msvc": "0.1.0"
  },
  "napi": {
    "binaryName": "clawkeys"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.0",
    "@types/node": "^22.10.2",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
}
